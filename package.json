{
  "name": "claude-code-jsonl-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "test": "vitest run",
    "lint": "pnpm --filter claude-code-jsonl-generator build && pnpm -r lint && eslint .",
    "fix": "pnpm -r fix && eslint . --fix",
    "check:generated-sync": "node scripts/check-generated-sync.mjs"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.4",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/github": "12.0.9",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.5",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
